# ============================================
# 夯土墙风蚀监测系统 - 环境变量模板
# 复制为 .env 后根据实际情况修改
# ============================================

# ---------- 基础配置 ----------
COMPOSE_PROJECT_NAME=rammed_earth_wall
TZ=Asia/Shanghai

# ---------- TimescaleDB ----------
TIMESCALEDB_VERSION=latest-pg16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMePlease_2026!
POSTGRES_DB=rammed_earth_wall
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data

# ---------- Redis ----------
REDIS_VERSION=7.2-alpine
REDIS_PASSWORD=RedisSecret_2026!
REDIS_PORT=6379

# ---------- MQTT Broker (Eclipse Mosquitto) ----------
MOSQUITTO_VERSION=2.0
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USER=wall_monitor
MQTT_PASSWORD=MQTT_Secret_2026!

# ---------- FastAPI Backend ----------
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:ChangeMePlease_2026!@timescaledb:5432/rammed_earth_wall
TIMESCALEDB_URL=postgresql://postgres:ChangeMePlease_2026!@timescaledb:5432/rammed_earth_wall
REDIS_URL=redis://:RedisSecret_2026!@redis:6379/0
MQTT_BROKER=mqtt
MQTT_PORT_INTERNAL=1883
MQTT_CLIENT_ID=backend_server
MQTT_TOPIC=wall/alert
MQTT_USERNAME=wall_monitor
MQTT_PASSWORD_INTERNAL=MQTT_Secret_2026!

# ---------- Nginx Frontend ----------
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# ---------- Sensor Simulator ----------
SIMULATOR_INTERVAL=300
SIMULATOR_SEGMENTS=8
SIMULATOR_GENERATE_HISTORICAL=true
SIMULATOR_HISTORICAL_DAYS=30

# 风速参数
SIM_WIND_SPEED_MIN=3.0
SIM_WIND_SPEED_MAX=14.0
SIM_WIND_SPEED_BIAS=0.0
SIM_WIND_GUST_FREQ=0.25
SIM_SEASONAL_FACTOR=1.3
SIM_DIURNAL_ENABLE=true
SIM_DOMINANT_WIND_DIR=225

# 含水量参数
SIM_MOISTURE_BASE=5.5
SIM_MOISTURE_BIAS=0.0
SIM_MOISTURE_VAR_MIN=0.5
SIM_MOISTURE_VAR_MAX=1.5
